# Copy to apps/api/.env.staging on the STAGING VPS (never commit).

DATABASE_URL=postgresql+asyncpg://skulpulse_app:CHANGE_APP_PASSWORD@pgbouncer:6432/skulpulse
MIGRATION_DATABASE_URL=postgresql+asyncpg://skulpulse:CHANGE_OWNER_PASSWORD@postgres:5432/skulpulse
REDIS_URL=redis://redis:6379/0

JWT_SECRET=DIFFERENT_FROM_PRODUCTION_openssl_rand_hex_32
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

CORS_ORIGINS=https://staging.app.skulpulse.com
PLATFORM_ADMIN_EMAIL=admin@skulpulse.com
PLATFORM_ADMIN_PASSWORD=StagingAdmin!ChangeMe
PLATFORM_BASE_FEE_UGX=100000

ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_JSON=true
REQUEST_LOG_BODY_HASH=true
MEDIA_STORAGE_PATH=/app/storage
