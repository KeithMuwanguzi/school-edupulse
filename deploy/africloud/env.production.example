# Copy to apps/api/.env.production on the PRODUCTION VPS (never commit).
# Adjust passwords before first boot.

DATABASE_URL=postgresql+asyncpg://skulpulse_app:CHANGE_APP_PASSWORD@pgbouncer:6432/skulpulse
MIGRATION_DATABASE_URL=postgresql+asyncpg://skulpulse:CHANGE_OWNER_PASSWORD@postgres:5432/skulpulse
REDIS_URL=redis://redis:6379/0

JWT_SECRET=f057e3e7128d51476a1762f4afdcbd18f0def411b64ca9db9fda628852a26fcd
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

CORS_ORIGINS=https://app.skulpulse.com
PLATFORM_ADMIN_EMAIL=admin@skulpulse.com
PLATFORM_ADMIN_PASSWORD=P@ssw0rd
PLATFORM_BASE_FEE_UGX=100000

ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_LOG_BODY_HASH=true
REQUEST_LOG_SAMPLE_RATE=0.25
MEDIA_STORAGE_PATH=/app/storage

# Horizontal scaling — workers per api container (replicas via deploy-prod.sh)
API_WORKERS=4

# Reverse proxy — required behind Caddy
TRUST_PROXY_HEADERS=true

# HttpOnly refresh cookie (cross-subdomain: app.* → api.*)
REFRESH_COOKIE_ENABLED=true
REFRESH_COOKIE_NAME=skulpulse_refresh
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_DOMAIN=.skulpulse.com
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=none

# Prometheus metrics — scrape with: Authorization: Bearer <token>
METRICS_TOKEN=28b6087925a7d3ea495a63212fd1b94f851d5d906957995351788b61723bf9ea

# Rate limiting (tune per deployment scale)
RATE_LIMIT_API_ENABLED=true
RATE_LIMIT_LOGIN_IP_PER_MINUTE=10
RATE_LIMIT_LOGIN_ID_PER_MINUTE=20
RATE_LIMIT_REFRESH_IP_PER_MINUTE=30
RATE_LIMIT_API_BURST=50
RATE_LIMIT_API_BURST_WINDOW_SECONDS=10
RATE_LIMIT_API_SUSTAINED_PER_MINUTE=300
RATE_LIMIT_API_USER_PER_MINUTE=600
RATE_LIMIT_VIOLATION_THRESHOLD=5
RATE_LIMIT_VIOLATION_WINDOW_SECONDS=300
RATE_LIMIT_BLOCK_SECONDS=900

# Allow platform admin "Reset all data" while testing; set false after go-live.
PLATFORM_ALLOW_DATA_RESET=false

# Outbound email — Resend (copy API key from Resend dashboard; never commit real key)
SMTP_ENABLED=true
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=re_deHUs1JJ_FCEdyXbXSW9SU8jJVuaKPxQv
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=info@skulpulse.com
SMTP_FROM_NAME=SkulPulse
TENANT_PORTAL_URL=https://app.skulpulse.com
PLATFORM_PORTAL_URL=https://app.skulpulse.com/platform/sign-in
