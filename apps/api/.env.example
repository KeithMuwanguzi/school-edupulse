# App traffic goes through PgBouncer; Alembic migrations use direct Postgres.
# Host ports are offset (compose publishes 56432/55432/6380) to avoid clashing
# with a local Postgres/PgBouncer/Redis already installed on the machine.
# App connects as the NON-superuser role skulpulse_app (created by the migration)
# so Postgres RLS is actually enforced. Migrations use the owner role skulpulse.
DATABASE_URL=postgresql+asyncpg://skulpulse_app:skulpulse_app@localhost:56432/skulpulse
MIGRATION_DATABASE_URL=postgresql+asyncpg://skulpulse:skulpulse@localhost:55432/skulpulse
REDIS_URL=redis://localhost:6380/0
JWT_SECRET=change-me-to-32-plus-random-bytes-please-0123456789
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:3000,http://localhost:3005
PLATFORM_ADMIN_EMAIL=admin@skulpulse.ug
PLATFORM_ADMIN_PASSWORD=ChangeMe!Admin2025
PLATFORM_BASE_FEE_UGX=100000
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_JSON=true
REQUEST_LOG_BODY_HASH=true

# Allow "Reset all data" in platform admin (set false after go-live with real schools).
PLATFORM_ALLOW_DATA_RESET=true
